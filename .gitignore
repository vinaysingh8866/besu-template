# Besu Network - Git Ignore

# Sensitive keys and secrets
keys/
*.key
*.pub
*ADMIN_ACCOUNTS.txt

# Hardhat / kanon_contracts (also has its own .gitignore — be explicit at the root)
kanon_contracts/node_modules/
kanon_contracts/cache/
kanon_contracts/artifacts/
kanon_contracts/typechain-types/
kanon_contracts/coverage/
kanon_contracts/.env
kanon_contracts/.env.*

# Blockchain data
data/
*.db
*.log

# Kubernetes local storage
local-path-provisioner/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Editor directories and files
.idea
.vscode
*.swp
*.swo
*~
.project
.classpath
.settings/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Terraform
deployment/terraform/**/.terraform/
deployment/terraform/**/.terraform.lock.hcl
deployment/terraform/**/terraform.tfstate
deployment/terraform/**/terraform.tfstate.backup
deployment/terraform/**/*.tfvars
!deployment/terraform/**/*.tfvars.example

# Backup files
*.bak
*.backup
*.old

# Temp files
tmp/
temp/
*.tmp

# Environment files
.env
.env.local
.env.*.local

# Don't ignore example files
!.env.example
!*.example

# Keep directory structure
!keys/.gitkeep
!data/.gitkeep

tests/*